# Raw data (downloaded from Kaggle)
data/raw/

# Processed data (generated by data/scripts/)
data/processed/

# VisDrone dataset (large, several GB)
data/VisDrone2019-DET/
data/subsets/

# Training artifacts (checkpoints, figures, large files)
results/
report/

# Pretrained model weights
models/

# PyTorch checkpoint files (safety net)
*.pt
*.pth

# Notebook checkpoints
.ipynb_checkpoints/
**/.ipynb_checkpoints/

# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/

# Virtual environments
.venv/
venv/
env/
.conda/

# Experiment trackers
wandb/
mlruns/

# OS / editor
.DS_Store
.vscode/

# Kaggle credentials (never commit)
.kaggle/
kaggle.json
.env

# Temporary YOLO labels (generated at runtime by _create_data_yaml())
**/labels/

# Ultralytics cache files
**/*.cache

# Markdown files (except README)
*.md
!README.md

.continue/
plan/

*.zip
